# ============================================
# Election Guide India — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ============================================

# --- Required ---
# Your Google API Key (from Google Cloud Console or AI Studio)
# Must have Gemini, Translation, and Custom Search APIs enabled
GOOGLE_API_KEY=your-google-api-key-here

# --- Optional ---
# Google Custom Search Engine ID (for real-time election news search)
# Create one at: https://programmablesearchengine.google.com/
# Restrict it to: eci.gov.in, election-related sites
CUSTOM_SEARCH_ENGINE_ID=your-custom-search-engine-id-here

# Server port (Cloud Run sets this automatically)
PORT=8080

# Node environment
NODE_ENV=production

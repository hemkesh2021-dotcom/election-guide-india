# ============================================
# Election Guide India — .gitignore
# ============================================

# --- Secrets & Environment ---
.env
.env.local
.env.*.local
*.key
*.pem
*.p12
service-account*.json

# --- Dependencies ---
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# --- Build Artifacts ---
dist/
build/
.cache/
*.tsbuildinfo

# --- OS Files ---
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# --- IDE / Editor ---
.vscode/
.idea/
*.code-workspace
.project
.classpath

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Docker ---
docker-compose.override.yml

# --- Google Cloud ---
.gcloudignore

# --- Testing ---
coverage/
.nyc_output/

# --- Misc ---
.env.production
.env.staging
tmp/
temp/
